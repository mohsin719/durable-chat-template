NODE_ENV=production
# Database - Pooler (used for runtime)
DATABASE_URL="postgresql://username:password@host:port/dbname?sslmode=require"

# Database - Direct (used for Prisma introspection)
DIRECT_URL="postgresql://username:password@host:port/dbname?sslmode=require"

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here

# Frontend origin (for CORS) - comma-separated for multiple origins
# Supports wildcard for Vercel preview deployments
WEB_ORIGIN=https://usnumhub.com,https://www.usnumhub.com
# For development only:
# WEB_ORIGIN=http://localhost:3000

# Cookie domain for auth cookies
COOKIE_DOMAIN=.usnumhub.com

# Telnyx
MOCK_TELNYX=false
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_MESSAGING_PROFILE_ID=your-messaging-profile-uuid
TELNYX_PUBLIC_KEY=your-telnyx-webhook-public-key

# Business Logic
NUMBER_LEASE_TTL_MINUTES=10
NUMBER_PRICE_CENTS=100
NUMBER_REUSE_COOLDOWN_MINUTES=30

# Admin Seed
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=your-admin-password

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Email (Brevo)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=support@yourdomain.com
BREVO_SENDER_NAME=YourAppName
BREVO_TEMPLATE_PASSWORD_RESET=1
BREVO_TEMPLATE_SIGNUP_VERIFICATION=2

# Security
BCRYPT_ROUNDS=12
ADMIN_WHATSAPP_E164=03474094312
# App   
APP_BASE_URL=https://your-domain.com
PORT=4000
